  "nodes": [
    {
      "id": "change",
      "label": "Change under assessment",
      "properties": {
        "description": "Refactored interrupt handler in overspeed_protection.c to reduce CPU load during\nhigh-frequency engine monitoring cycles. The interrupt latency optimization\nintroduced a 19 ms delay in the overspeed protection response path, causing\nFADEC-REQ-001 (<=50 ms) to be violated at 63.2 ms.\n\nDAL-A requirement. Release blocking. Requires immediate root cause analysis\nand re-verification before any further integration."
      },
      "type": "change"
    },
